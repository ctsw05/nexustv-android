<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@color/bg_secondary"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="16dp"
        android:paddingRight="16dp">

        <Button
            android:id="@+id/btnBack"
            style="@style/TVTabButton"
            android:text="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Settings"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:paddingRight="80dp" />
    </LinearLayout>

    <!-- Body: two columns -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- Left: Playlist list -->
        <LinearLayout
            android:layout_width="340dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MY PLAYLISTS"
                android:textSize="11sp"
                android:textColor="@color/accent"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/playlistList"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Hidden channels -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HIDDEN CHANNELS"
                android:textSize="11sp"
                android:textColor="@color/accent"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/hiddenCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/text_muted"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnUnhideAll"
                style="@style/TVButton"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="Unhide All Channels" />

        </LinearLayout>

        <!-- Divider -->
        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="@color/border" />

        <!-- Right: Add Playlist form -->
        <ScrollView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ADD PLAYLIST"
                    android:textSize="11sp"
                    android:textColor="@color/accent"
                    android:letterSpacing="0.1"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="16dp" />

                <!-- Name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Playlist Name"
                    android:textSize="12sp"
                    android:textColor="@color/text_muted"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/inputName"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:hint="My Playlist"
                    android:textColorHint="@color/text_muted"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:background="@drawable/search_bg"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:singleLine="true"
                    android:layout_marginBottom="12dp" />

                <!-- M3U URL -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="M3U URL"
                    android:textSize="12sp"
                    android:textColor="@color/text_muted"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/inputUrl"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:hint="http://example.com/playlist.m3u"
                    android:textColorHint="@color/text_muted"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:background="@drawable/search_bg"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:singleLine="true"
                    android:inputType="textUri"
                    android:layout_marginBottom="8dp" />

                <!-- OR divider + file picker -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/border" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  OR  "
                        android:textSize="11sp"
                        android:textColor="@color/text_muted" />
                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/border" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnBrowseFile"
                    style="@style/TVButton"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="📂  Browse Local M3U File"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/selectedFileName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/accent"
                    android:gravity="center"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone" />

                <!-- EPG URL -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EPG / TV Guide URL (optional)"
                    android:textSize="12sp"
                    android:textColor="@color/text_muted"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/inputEpgUrl"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:hint="http://example.com/epg.xml"
                    android:textColorHint="@color/text_muted"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:background="@drawable/search_bg"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:singleLine="true"
                    android:inputType="textUri"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="If your M3U contains a url-tvg= tag, the EPG is detected automatically."
                    android:textSize="11sp"
                    android:textColor="@color/text_muted"
                    android:layout_marginBottom="20dp" />

                <!-- Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnSave"
                        style="@style/TVButton"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_marginRight="10dp"
                        android:text="Save Playlist" />

                    <Button
                        android:id="@+id/btnClear"
                        style="@style/TVButton"
                        android:text="Clear" />
                </LinearLayout>

                <TextView
                    android:id="@+id/statusMsg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/text_muted"
                    android:layout_marginTop="16dp"
                    android:gravity="center" />

                <!-- Tip: hide channels -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/border"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tip: Long-press any channel in the list to hide it or add to favorites."
                    android:textSize="12sp"
                    android:textColor="@color/text_muted" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/border"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="APP"
                    android:textSize="11sp"
                    android:textColor="@color/accent"
                    android:letterSpacing="0.1"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/btnCheckUpdate"
                    style="@style/TVButton"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="🔄  Check for Updates" />

            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</LinearLayout>
