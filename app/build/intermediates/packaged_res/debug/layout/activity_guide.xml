<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:id="@+id/guideHeader"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@color/bg_secondary"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingLeft="12dp"
            android:paddingRight="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📺  TV GUIDE"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium"
                android:layout_marginRight="16dp"/>

            <TextView
                android:id="@+id/guideTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/text_muted"
                android:layout_marginRight="8dp"/>

            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

            <TextView
                android:id="@+id/guideSelectedInfo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:textSize="12sp"
                android:textColor="@color/accent"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginRight="12dp"/>

            <Button
                android:id="@+id/btnGuideWatch"
                style="@style/TVButton"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="▶  Watch"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:layout_marginRight="8dp"/>

            <Button
                android:id="@+id/btnGuideClose"
                style="@style/TVTabButton"
                android:text="✕  Close"/>
        </LinearLayout>

        <!-- Time header + channel col header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:background="@color/bg_primary">

            <!-- Corner spacer matching channel col width -->
            <TextView
                android:layout_width="140dp"
                android:layout_height="match_parent"
                android:text="Channel"
                android:textSize="10sp"
                android:textColor="@color/text_muted"
                android:gravity="center"
                android:background="@color/bg_secondary"/>

            <View android:layout_width="1dp" android:layout_height="match_parent"
                android:background="@color/border"/>

            <!-- Scrollable time header — synced with grid scroll -->
            <HorizontalScrollView
                android:id="@+id/timeHeaderScroll"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:scrollbars="none"
                android:overScrollMode="never"
                android:focusable="false">

                <LinearLayout
                    android:id="@+id/epgTimeHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"/>
            </HorizontalScrollView>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/border"/>

        <!-- Main body: channel col + grid rows -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <!-- Fixed channel column -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/guideChannelCol"
                android:layout_width="140dp"
                android:layout_height="match_parent"
                android:background="@color/bg_secondary"
                android:focusable="false"
                android:overScrollMode="never"/>

            <View android:layout_width="1dp" android:layout_height="match_parent"
                android:background="@color/border"/>

            <!-- Grid rows (RecyclerView, each row is a HorizontalScrollView + EpgGridView) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/epgRowList"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:focusable="true"
                android:overScrollMode="never"/>
        </LinearLayout>
    </LinearLayout>

    <!-- PiP player (top-right, overlay mode only) -->
    <com.google.android.exoplayer2.ui.StyledPlayerView
        android:id="@+id/guidePipPlayer"
        android:layout_width="260dp"
        android:layout_height="146dp"
        android:layout_gravity="top|right"
        android:layout_margin="10dp"
        android:background="@color/bg_primary"
        android:visibility="gone"
        android:focusable="false"/>

</FrameLayout>
