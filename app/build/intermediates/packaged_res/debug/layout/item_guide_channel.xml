<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/channel_item_bg"
    android:paddingLeft="10dp"
    android:paddingRight="10dp"
    android:focusable="true"
    android:clickable="true"
    android:descendantFocusability="blocksDescendants"
    android:layout_marginBottom="2dp">

    <ImageView
        android:id="@+id/guideLogo"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:scaleType="fitCenter"
        android:contentDescription="logo" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="8dp">

        <TextView
            android:id="@+id/guideChannelName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/guideCurrentProgram"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/accent"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/guideNextProgram"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="@color/text_muted"
            android:maxLines="1"
            android:ellipsize="end" />

        <ProgressBar
            android:id="@+id/guideProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_marginTop="3dp"
            android:max="100"
            android:progressTint="@color/accent"
            android:progressBackgroundTint="@color/border" />

    </LinearLayout>

</LinearLayout>
