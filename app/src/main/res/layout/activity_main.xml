<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/rootLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/bg_primary">

        <!-- ── Navbar ── -->
        <LinearLayout
            android:id="@+id/navbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/nav_height"
            android:orientation="horizontal"
            android:background="@color/bg_secondary"
            android:gravity="center_vertical"
            android:paddingLeft="12dp"
            android:paddingRight="12dp">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@mipmap/ic_launcher"
                android:contentDescription="logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nexus TV"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium"
                android:layout_marginLeft="8dp"
                android:layout_marginRight="20dp" />

            <!-- Tabs -->
            <Button android:id="@+id/tabAll"
                style="@style/TVTabButton"
                android:layout_marginRight="4dp"
                android:text="All Channels"
                android:nextFocusDown="@id/channelList" />

            <Button android:id="@+id/tabFavorites"
                style="@style/TVTabButton"
                android:layout_marginRight="4dp"
                android:text="Favorites"
                android:nextFocusDown="@id/channelList" />

            <Button android:id="@+id/tabRecent"
                style="@style/TVTabButton"
                android:text="Recent"
                android:nextFocusDown="@id/channelList" />

            <!-- Spacer -->
            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

            <Button android:id="@+id/btnFullscreen"
                style="@style/TVTabButton"
                android:text="[ ]"
                android:layout_marginRight="4dp"
                android:nextFocusDown="@id/channelList" />

            <Button android:id="@+id/btnSettings"
                style="@style/TVTabButton"
                android:text="Settings"
                android:nextFocusDown="@id/channelList" />

        </LinearLayout>

        <!-- ── Body ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <!-- Channel list -->
            <LinearLayout
                android:id="@+id/channelPanel"
                android:layout_width="@dimen/channel_list_width"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:background="@color/bg_primary">

                <TextView
                    android:id="@+id/channelCountLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingLeft="10dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="4dp"
                    android:textSize="11sp"
                    android:textColor="@color/text_muted" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/channelList"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:paddingLeft="6dp"
                    android:paddingRight="6dp"
                    android:clipToPadding="false"
                    android:scrollbars="vertical"
                    android:scrollbarStyle="outsideOverlay"
                    android:focusable="true"
                    android:focusableInTouchMode="true" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:id="@+id/panelDivider"
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/border" />

            <!-- Player + info bar -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@color/bg_primary">

                <com.google.android.exoplayer2.ui.StyledPlayerView
                    android:id="@+id/playerView"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:background="@color/bg_primary"
                    android:focusable="false"
                    android:focusableInTouchMode="false" />

                <!-- Info bar -->
                <LinearLayout
                    android:id="@+id/infoBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/bg_secondary"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NOW PLAYING"
                        android:textSize="9sp"
                        android:textColor="@color/accent"
                        android:letterSpacing="0.1"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/nowPlayingName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/select_channel"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-medium"
                        android:ellipsize="end"
                        android:maxLines="1" />

                    <TextView
                        android:id="@+id/nowPlayingGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="@color/text_muted"
                        android:ellipsize="end"
                        android:maxLines="1" />

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/border"
                        android:layout_marginTop="6dp" android:layout_marginBottom="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ON NOW"
                        android:textSize="9sp"
                        android:textColor="@color/accent"
                        android:letterSpacing="0.1"
                        android:fontFamily="sans-serif-medium" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="2dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/epgCurrentTitle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="13sp"
                                android:textColor="@color/text_primary"
                                android:fontFamily="sans-serif-medium"
                                android:maxLines="1"
                                android:ellipsize="end" />

                            <TextView
                                android:id="@+id/epgCurrentSubtitle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="11sp"
                                android:textColor="@color/accent"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:visibility="gone" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/epgCurrentTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="11sp"
                            android:textColor="@color/text_muted"
                            android:layout_marginLeft="8dp" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/epgProgressBar"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="3dp"
                        android:layout_marginTop="3dp"
                        android:layout_marginBottom="6dp"
                        android:max="100"
                        android:progressTint="@color/accent"
                        android:progressBackgroundTint="@color/border" />

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/border" android:layout_marginBottom="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="UP NEXT"
                        android:textSize="9sp"
                        android:textColor="@color/text_muted"
                        android:letterSpacing="0.1"
                        android:fontFamily="sans-serif-medium" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="2dp">

                        <TextView
                            android:id="@+id/epgNext1Title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <TextView
                            android:id="@+id/epgNext1Time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="11sp"
                            android:textColor="@color/text_muted"
                            android:layout_marginLeft="8dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="3dp">

                        <TextView
                            android:id="@+id/epgNext2Title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="12sp"
                            android:textColor="@color/text_muted"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <TextView
                            android:id="@+id/epgNext2Time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="11sp"
                            android:textColor="@color/text_muted"
                            android:layout_marginLeft="8dp" />
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- OSD Card (fullscreen only) -->
    <LinearLayout
        android:id="@+id/osdCard"
        android:layout_width="420dp"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|left"
        android:layout_marginLeft="16dp"
        android:layout_marginBottom="16dp"
        android:orientation="vertical"
        android:background="#CC000000"
        android:paddingLeft="14dp"
        android:paddingRight="14dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:id="@+id/osdLogo"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:scaleType="fitCenter"
                android:contentDescription="logo"
                android:layout_marginRight="12dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/osdChannelName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/osdChannelGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/text_muted"
                    android:maxLines="1" />
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/border" android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/osdProgramTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:maxLines="2"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/osdProgramSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/accent"
            android:maxLines="1"
            android:ellipsize="end"
            android:visibility="gone" />

        <TextView
            android:id="@+id/osdProgramTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/text_muted"
            android:layout_marginTop="2dp" />

        <ProgressBar
            android:id="@+id/osdProgressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_marginTop="4dp"
            android:max="100"
            android:progressTint="@color/accent"
            android:progressBackgroundTint="@color/border" />

        <TextView
            android:id="@+id/osdProgramDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginTop="4dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Help Overlay -->
    <FrameLayout
        android:id="@+id/helpOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E6000000"
        android:visibility="gone"
        android:focusable="true"
        android:focusableInTouchMode="true">

        <LinearLayout
            android:layout_width="860dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:background="#141414"
            android:padding="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="REMOTE CONTROL GUIDE"
                    android:textSize="18sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-medium" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Press Back or OK to close"
                    android:textSize="12sp"
                    android:textColor="@color/text_muted" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/helpColMain"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginRight="16dp" />

                <View android:layout_width="1dp" android:layout_height="match_parent"
                    android:background="@color/border" android:layout_marginRight="16dp"/>

                <LinearLayout
                    android:id="@+id/helpColFullscreen"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <!-- Toast -->
    <TextView
        android:id="@+id/osdToast"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|right"
        android:layout_marginTop="60dp"
        android:layout_marginRight="16dp"
        android:background="#CC000000"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:visibility="gone" />

</FrameLayout>
