<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingLeft="12dp"
    android:paddingRight="12dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:background="@color/bg_secondary"
    android:focusable="true"
    android:focusableInTouchMode="false"
    android:clickable="true">

    <!-- Time + live badge row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="3dp">

        <TextView
            android:id="@+id/epgItemTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="11sp"
            android:textColor="@color/text_muted" />

        <TextView
            android:id="@+id/epgItemLiveBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NOW"
            android:textSize="9sp"
            android:textColor="#FFFFFF"
            android:background="@color/accent"
            android:paddingLeft="5dp"
            android:paddingRight="5dp"
            android:paddingTop="1dp"
            android:paddingBottom="1dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Progress bar (only for current program) -->
    <ProgressBar
        android:id="@+id/epgItemProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_marginBottom="4dp"
        android:max="100"
        android:progressTint="@color/accent"
        android:progressBackgroundTint="@color/border"
        android:visibility="gone" />

    <!-- Title -->
    <TextView
        android:id="@+id/epgItemTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="@color/text_primary"
        android:fontFamily="sans-serif-medium"
        android:maxLines="1"
        android:ellipsize="end" />

    <!-- Description -->
    <TextView
        android:id="@+id/epgItemDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textColor="@color/text_muted"
        android:maxLines="2"
        android:ellipsize="end"
        android:layout_marginTop="2dp"
        android:visibility="gone" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border"
        android:layout_marginTop="8dp" />

</LinearLayout>
